generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model DailyReport {
  id        String   @id @default(cuid())
  date      DateTime
  activity  String
  createdAt DateTime @default(now())
}